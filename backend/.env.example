# Base de datos
DATABASE_URL=postgresql+asyncpg://tiltil:tiltil_dev@localhost:5432/portal_instalacion
DATABASE_URL_SYNC=postgresql+psycopg2://tiltil:tiltil_dev@localhost:5432/portal_instalacion

# JWT
JWT_SECRET=dev-secret-change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS (lista JSON con los orígenes permitidos)
CORS_ORIGINS=["http://localhost:3000"]

# Identidad de empresa (para Excel SEC y plantillas)
EMPRESA_CODIGO=050
EMPRESA_NOMBRE=Empresa Electrica Municipal de TilTil

# Storage de archivos adjuntos (volumen montado en Docker)
UPLOADS_DIR=/app/uploads
MAX_UPLOAD_MB=20

# SMTP — dejar SMTP_HOST vacío para registrar correos sólo en la tabla
# `notificaciones` (estado=pendiente) sin enviar nada.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM=no-reply@electricatiltil.cl
SMTP_FROM_NAME=Electrica TilTil

# Destinatario interno para avisos cuando el cliente completa información
ADMIN_NOTIFY_EMAIL=admin@tiltil.cl

# URL pública del portal (usada en links de correo)
PORTAL_PUBLIC_URL=http://localhost:3000
