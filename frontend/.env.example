# URL del backend visible desde el navegador (cliente Next.js).
# En producción debe apuntar a la URL pública del API.
NEXT_PUBLIC_API_URL=http://localhost:8001

# URL del backend desde el server-side de Next (server actions, route handlers,
# server components). En Docker se resuelve por el nombre del servicio.
API_URL_INTERNAL=http://backend:8000
