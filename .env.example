# docker compose lee este archivo para sustitucion ${VAR} en docker-compose.yml.
# Copia a .env y ajusta para tu entorno. SOLO incluye vars necesarias para
# build args u otra sustitucion de compose; el runtime de cada servicio se
# carga via env_file: en docker-compose.yml.

# Build args del frontend (se inlinean en el bundle durante next build).
# Si cambias estas vars hay que rebuild: docker compose build frontend
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_API_URL=
